{
  "config": {
    "step": {
      "user": {
        "title": "Default Config Manager",
        "description": "[Default Config](https://www.home-assistant.io/integrations/default_config/) Version: {default_config_version}\n\nStatus: {status}"
      },
      "init": {
        "title": "Default Config Manager",
        "description": "[Default Config](https://www.home-assistant.io/integrations/default_config/) Version: {default_config_version}",
        "data": {
          "advanced_mode": "Enable advanced mode"
        }
      }
    },
    "error": {
      "default_config_enabled": "default_config is still enabled in configuration.yaml. Remove it to manage default_config here.",
      "advanced_warning": "Advanced mode allows disabling default_config integrations. Use with caution."
    }
  },
  "options": {
    "step": {
      "init_yaml": {
        "title": "Default Config Manager",
        "description": "[Default Config](https://www.home-assistant.io/integrations/default_config/) Version: {default_config_version}",
        "data": {
          "mode": "Status"
        }
      },
      "init_managed": {
        "title": "Default Config Manager",
        "description": "[Default Config](https://www.home-assistant.io/integrations/default_config/) Version: {default_config_version}\n\nStatus: {status}",
        "data": {
          "mode": "Status",
          "advanced_mode": "Enable advanced mode",
          "integration_list": "Managed Integrations"
        }
      }
    }
  },
  "issues": {
    "restart_required": {
      "title": "Restart Required",
      "description": "Changes to your Default Config integrations have been detected. A restart is required for these changes to take effect.",
      "fix_flow": {
        "step": {
          "confirm": {
            "title": "Restart Home Assistant",
            "description": "Are you sure you want to restart Home Assistant to apply your changes?"
          }
        }
      }
    }
  }
}
